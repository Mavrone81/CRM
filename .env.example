# Copy to .env on the server (git-ignored, server-managed). Never commit real values.

# Anthropic API key for AI reply classification (server falls back to keyword
# matching if unset). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Single-password login gate for the web dashboard (web/).
# Defaults to petsadmin / P@55w0rd888 if unset — override in production.
AUTH_USER=petsadmin
AUTH_PASSWORD=P@55w0rd888
# Secret used to sign the session cookie. MUST be set to a long random string in
# production (e.g. `openssl rand -hex 32`) — otherwise sessions are forgeable.
AUTH_SECRET=change-me-to-a-long-random-string
