# Copy to .env on the server (git-ignored, server-managed). Never commit real values.

# Anthropic API key for AI reply classification (server falls back to keyword
# matching if unset). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Single-password login gate for the web dashboard (web/).
# Username falls back to "petsadmin" if unset. AUTH_PASSWORD has NO default —
# login is disabled until it is set here. Set a real password below.
AUTH_USER=petsadmin
AUTH_PASSWORD=set-a-real-password-here
# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
# If unset, sessions are unsigned/forgeable — always set this.
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Telegram bot token from @BotFather (server-side only, never commit the real one)
TELEGRAM_TOKEN=
